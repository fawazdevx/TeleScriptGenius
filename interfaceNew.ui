                            <property name="styleSheet">
                             <string notr="true">/* COMBOBOX BASE */
QComboBox {
    background-color: rgba(15, 20, 30, 220);
    border: 1px solid rgba(0, 229, 255, 80);
    border-radius: 14px;
    padding: 8px 14px;
    color: #E6F9FF;
}

/* REMOVE DEFAULT ARROW */
QComboBox::drop-down {
    border: none;
}

/* DROPDOWN LIST */
QComboBox QAbstractItemView {
    background-color: rgba(10, 14, 20, 245);
    border-radius: 14px;
    padding: 6px;
    selection-background-color: rgba(0, 229, 255, 60);
    outline: none;
}

/* INDIVIDUAL ITEMS */
QComboBox QAbstractItemView::item {
    height: 36px;
    border-radius: 10px;
    padding-left: 12px;
    color: #E6F9FF;
}

/* HOVER EFFECT */
QComboBox QAbstractItemView::item:hover {
    background-color: rgba(0, 229, 255, 50);
}

/* SELECTED ITEM */
QComboBox QAbstractItemView::item:selected {
    background-color: rgba(0, 229, 255, 80);
}
</string>
