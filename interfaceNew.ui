                 <item>
                  <widget class="QFrame" name="heroCard">
                   <property name="sizePolicy">
                    <sizepolicy hsizetype="Preferred" vsizetype="Fixed">
                     <horstretch>0</horstretch>
                     <verstretch>0</verstretch>
                    </sizepolicy>
                   </property>
                   <property name="minimumSize">
                    <size>
                     <width>0</width>
                     <height>300</height>
                    </size>
                   </property>
                   <property name="styleSheet">
                    <string notr="true">/* HERO CARD */
QFrame#heroCard {
    background-color: qradialgradient(
        cx:0.25, cy:0.2, radius:1.1,
        fx:0.25, fy:0.2,
        stop:0 rgba(0, 229, 255, 35),
        stop:0.35 rgba(12, 18, 28, 215),
        stop:1 rgba(10, 14, 20, 235)
    );

    border-radius: 22px;
    border: 1px solid rgba(0, 229, 255, 70);
}

/* ALL LABELS INSIDE HERO CARD */
QFrame#heroCard QLabel {
    background: transparent;
    color: #E6F9FF;
    font-weight: 500;
}

/* TITLE LABEL */
QFrame#heroCard QLabel#heroTitle {
    color: #00E5FF;
    font-size: 22px;
    font-weight: 700;
}

/* SUBTITLE / VERSION */
QFrame#heroCard QLabel#heroSub {
    color: rgba(200, 255, 255, 160);
    font-size: 12px;
}

/* PARAGRAPH TEXT */
QFrame#heroCard QLabel#heroText {
    color: rgba(220, 240, 255, 180);
    font-size: 13px;
