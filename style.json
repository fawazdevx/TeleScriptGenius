{
	"QMainWindow":[
		{
			"tittle":"TeleScriptGenius",
			"icon":":images/Telescript.png",
			"frameless": true,
			"transluscentBg": true,
			"sizeGrip": "sizeGrip",
			"navigation":[
				{
					"minimize":"minimize_window_btn",
					"close": "close_window_btn",
					"restore":[
						{
							"buttonName": "restore_window_btn",
							"normalIcon": ":/icons/icons/square.svg",
							"maximizedIcon": ":/icons/icons/copy.svg"
						}
					],
					"moveWindow": "headerContainer",
					"tittleBar": "headerContainer"
				}
			]
		}
	],
	"QCustomSlideMenu": [
		{
			"name": "leftMenuContainer",
			"defaultSize": [{
				"width": 65,
				"height": "parent"
			}],
			"collapsedSize": [{
				"width": 65,
				"height": "parent"
			}],
			"expandedSize": [{
				"width": 150,
				"height": "parent"
			}],
			"toggleButton": [{
				"buttonName": "menuBtn",
				"icons": [{
					"whenMenuIsCollapsed": ":/icons/icons/align-justify.svg",
					"whenMenuIsExpanded": ":/icons/icons/chevron-left.svg"
				}]
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}]
		},
		{
			"name": "centerMenuContainer",
			"defaultSize": [{
				"width": 0,
				"height": "parent"
			}],
			"collapsedSize": [{
				"width": 0,
				"height": "parent"
			}],
			"expandedSize": [{
				"width": 300,
				"height": "parent"
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}]
		},
		{
			"name": "rightMenuContainer",
			"defaultSize": [{
				"width": 0,
				"height": "auto"
			}],
			"collapsedSize": [{
				"width": 0,
				"height": "auto"
			}],
			"expandedSize": [{
				"width": 300,
				"height": "auto"
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}]
		},
		{
			"name": "popupNotificationContainer",
			"defaultSize": [{
				"width": 0,
				"height": "auto"
			}],
			"collapsedSize": [{
				"width": 0,
				"height": "auto"
			}],
			"expandedSize": [{
				"width": 500,
				"height": 100
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}],
			"floatPosition": [
				{
					"relativeTo": "centralwidget",
					"position": "top-center",
					"shadow":[
						{
							"color": "#000",
							"blurRadius": 20,
							"xOffset": 0,
							"yOffset": 0
						}
					]
				}
			],
			"toggleButton": [{
				"buttonName": "notificationBtn"
				}]
		}
	],
	"QStackedWidget":[
		{
			"name":"mainPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"homeBtn": "home_page",
							"genBtn": "temp_page",
							"routerBtn": "router_page",
							"linkBtn": "linkCheck_page",
							"regionsBtn": "region_page",
							"scriptsBtn": "scripts_page",
							"aRegBtn": "asaba10G_page",
							"eRegBtn": "enugu10G_page",
							"kRegBtn": "kano10G_page",
							"oRegBtn": "owerri10G_page",
							"aRegBtnAV": "asabaAV_page",
							"eRegBtnAV": "enuguAV_page",
							"kRegBtnAV": "kanoAV_page",
							"oRegBtnAV": "owerriAV_page"
						}
					]
				}
			]
		},
		{
			"name":"centerMenuPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"settingsBtn": "page",
							"infoBtn": "page_2",
							"helpBtn": "page_3"
						}
					]
				}
			]
		},
		{
			"name":"rightMenuPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"moreMenuBtn": "page_5",
							"profileMenuBtn": "page_4"
						}
					]
				}
			]
		},
		{
			"name":"mainPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"getStartBtn": "temp_page",
							"aviatBtn": "regionAV_page",
							"ml10GBtn": "region10G_page"
						}
					]
				}
			]
		},
		{
			"name":"mainPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"backRBtn": "temp_page",
							"backAVRBtn": "temp_page",
							"backrsBtn": "temp_page",
							"backlcBtn": "temp_page",
							"backABtn": "region10G_page",
							"backEBtn": "region10G_page",
							"backKBtn": "region10G_page",
							"backOBtn": "region10G_page",
							"backABtnAV": "regionAV_page",
							"backEBtnAV": "regionAV_page",
							"backKBtnAV": "regionAV_page",
							"backOBtnAV": "regionAV_page"
						}
					]
				}
			]
		}
	],
	"QPushButtonGroup": [
		{
			"Buttons": [
				"homeBtn",
				"genBtn",
				"regionsBtn",
				"scriptsBtn"
			],
			"Style":[
				{
					"Active": "background-color: #1f232a;",
					"NotActive": "background-color: transparent;"
				}
			]
		},
		{
			"Buttons": [
				"settingsBtn",
				"infoBtn",
				"helpBtn"
			],
			"Style":[
				{
					"Active": "background-color: #2c313c;",
					"NotActive": "background-color: transparent;"
				}
			]
		}
	]
}