{
	"QMainWindow":[
		{
			"tittle":"TeleScriptGenius",
			"icon":":images/Telescript.png",
			"frameless": true,
			"transluscentBg": true,
			"sizeGrip": "sizeGrip",
			"navigation":[
				{
					"minimize":"minimize_window_btn",
					"close": "close_window_btn",
					"restore":[
						{
							"buttonName": "restore_window_btn",
							"normalIcon": ":/icons/icons/square.svg",
							"maximizedIcon": ":/icons/icons/copy.svg"
						}
					],
					"moveWindow": "headerContainer",
					"tittleBar": "headerContainer"
				}
			]
		}
	],
	"QCustomSlideMenu": [
		{
			"name": "leftMenuContainer",
			"defaultSize": [{
				"width": 65,
				"height": "parent"
			}],
			"collapsedSize": [{
				"width": 65,
				"height": "parent"
			}],
			"expandedSize": [{
				"width": 150,
				"height": "parent"
			}],
			"toggleButton": [{
				"buttonName": "menuBtn",
				"icons": [{
					"whenMenuIsCollapsed": ":/icons/icons/align-justify.svg",
					"whenMenuIsExpanded": ":/icons/icons/chevron-left.svg"
				}]
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}]
		},
		{
			"name": "rightMenuContainer",
			"defaultSize": [{
				"width": 0,
				"height": "auto"
			}],
			"collapsedSize": [{
				"width": 0,
				"height": "auto"
			}],
			"expandedSize": [{
				"width": 300,
				"height": "auto"
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}]
		},
		{
			"name": "popupNotificationContainer",
			"defaultSize": [{
				"width": 0,
				"height": "auto"
			}],
			"collapsedSize": [{
				"width": 0,
				"height": "auto"
			}],
			"expandedSize": [{
				"width": 500,
				"height": 100
			}],
			"menuTransitionAnimation": [{
				"animationDuration": 500,
				"animationEasingCurve": "Linear"
			}],
			"floatPosition": [
				{
					"relativeTo": "centralwidget",
					"position": "top-center",
					"shadow":[
						{
							"color": "#000",
							"blurRadius": 20,
							"xOffset": 0,
							"yOffset": 0
						}
					]
				}
			],
			"toggleButton": [{
				"buttonName": "notificationBtn"
				}]
		}
	],
	"QStackedWidget":[
		{
			"name":"mainPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"genQuickBtn": "generator_page",
							"startQuickBtn": "generator_page",
							"linkQuickBtn": "link_page"
						}
					]
				}
			]
		},
		{
			"name":"mainPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"dashboardBtn": "home_page",
							"genBtn": "generator_page",
							"linkBtn": "link_page",
							"settingBtn": "settingsPage",
							"aboutBtn": "aboutPage"
						}
					]
				}
			]
		},
		{
			"name":"rightMenuPages",
			"navigation":[
				{
					"navigationButtons":[
						{
							"moreMenuBtn": "page_5",
							"profileMenuBtn": "page_4"
						}
					]
				}
			]
		}
	],
	"QPushButtonGroup": [
		{
			"Buttons": [
				"dashboardBtn",
				"genBtn",
				"linkBtn",
				"settingBtn"
			],
			"Style":[
				{
					"Active": "background-color: #1f232a;",
					"NotActive": "background-color: transparent;"
				}
			]
		},
		{
			"Buttons": [
				"settingsBtn",
				"infoBtn",
				"helpBtn"
			],
			"Style":[
				{
					"Active": "background-color: #2c313c;",
					"NotActive": "background-color: transparent;"
				}
			]
		}
	]
}